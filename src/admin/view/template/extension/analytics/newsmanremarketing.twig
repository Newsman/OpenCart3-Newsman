{{ header }}{{ column_left }}
<div id="content">
    <div class="page-header">
        <div class="container-fluid">
            <div class="pull-right">
                <button type="submit" form="form-analytics" data-toggle="tooltip" title="{{ button_save }}"
                        class="btn btn-primary"><i class="fa fa-save"></i></button>
                <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i
                            class="fa fa-reply"></i></a></div>
            <h1>{{ heading_title }}</h1>
            <ul class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ul>
            |&nbsp;<a href="{{ url_newsman_settings }}" title="text_newsman_settings">{{ text_newsman_settings }}</a>
        </div>
    </div>
    <div class="container-fluid">
        {% if error_warning %}
            <div class="alert alert-danger alert-dismissible"><i
                        class="fa fa-exclamation-circle"></i> {{ error_warning }}
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        {% endif %}
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
            </div>
            <div class="panel-body">
                <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-analytics"
                      class="form-horizontal">
                    <div class="alert alert-info"><i class="fa fa-info-circle"></i> {{ text_signup }}
                        <button type="button" class="close" data-dismiss="alert">&times;</button>
                    </div>
                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-code">{{ entry_tracking }}</label>
                        <div class="col-sm-10">
                            <input name="analytics_newsmanremarketing_trackingid" placeholder="{{ entry_tracking }}"
                                   id="input-code" class="form-control"
                                   value="{{ analytics_newsmanremarketing_trackingid }}">
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
                        <div class="col-sm-10">
                            <select name="analytics_newsmanremarketing_status" id="input-status" class="form-control">
                                <option value="1"
                                        {% if analytics_newsmanremarketing_status %}selected{% endif %}>{{ text_enabled }}</option>
                                <option value="0"
                                        {% if not analytics_newsmanremarketing_status %}selected{% endif %}>{{ text_disabled }}</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-anonymize-ip">{{ entry_anonymize_ip }}</label>
                        <div class="col-sm-10">
                            <select name="analytics_newsmanremarketing_anonymize_ip" id="input-anonymize-ip" class="form-control">
                                <option value="1"
                                        {% if analytics_newsmanremarketing_anonymize_ip %}selected{% endif %}>{{ text_enabled }}</option>
                                <option value="0"
                                        {% if not analytics_newsmanremarketing_anonymize_ip %}selected{% endif %}>{{ text_disabled }}</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-send-telephone">{{ entry_send_telephone }}</label>
                        <div class="col-sm-10">
                            <select name="analytics_newsmanremarketing_send_telephone" id="input-send-telephone" class="form-control">
                                <option value="1"
                                        {% if analytics_newsmanremarketing_send_telephone %}selected{% endif %}>{{ text_enabled }}</option>
                                <option value="0"
                                        {% if not analytics_newsmanremarketing_send_telephone %}selected{% endif %}>{{ text_disabled }}</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-code">{{ entry_order_date }}</label>
                        <div class="col-sm-10">
                            <input name="analytics_newsmanremarketing_order_date" placeholder="{{ entry_order_date }}"
                                   id="input-code" class="form-control"
                                   value="{{ analytics_newsmanremarketing_order_date }}">
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{{ footer }} 
