{{ header }}{{ column_left }}
<div id="content">
    <div class="page-header">
        <div class="container-fluid">
            <h1><img src="{{ logo }}" alt="{{ heading_title }}" style="height: 30px;" /></h1>
            <span class="help-block"><a href="https://www.newsman.com/" target="_blank">www.newsman.com</a> | {{ text_version }}: {{ newsman_version }}</span>
            <ul class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <div class="container-fluid">
        <div style="margin-bottom: 20px; font-size: 1.2em;">
            <b><i class="fa fa-cog"></i> {{ text_setup_for_store }}</b>
        </div>
        <div id="alerts">
            {% if success %}
                <div class="alert alert-success alert-dismissible" role="alert">
                    <button type="button" class="close" data-dismiss="alert" aria-label="{{ text_close }}"><span aria-hidden="true"><i class="fa fa-close"></i></span></button>
                    <i class="fa fa-check-circle" aria-hidden="true"></i>&nbsp;{{ success }}
                </div>
            {% endif %}
            {% if error %}
                <div class="alert alert-danger alert-dismissible" role="alert">
                    <button type="button" class="close" data-dismiss="alert" aria-label="{{ text_close }}"><span aria-hidden="true"><i class="fa fa-close"></i></span></button>
                    <i class="fa fa-exclamation-triangle" aria-hidden="true"></i>&nbsp;{{ error }}
                </div>
            {% endif %}
            {% if warning %}
                <div class="alert alert-warning alert-dismissible" role="alert">
                    <button type="button" class="close" data-dismiss="alert" aria-label="{{ text_close }}"><i class="fa fa-close"></i></button>
                    <i class="fa fa-info-circle"></i>&nbsp;{{ warning }}
                </div>
            {% endif %}
        </div>
    </div>

    {% if error %}
        <div class="container-fluid">
            <h4>{{ text_step2_retry }}</h4>
            <div style="padding-top: 5px;">
                <a style="background: #ad0100" href="{{ oauth_url }}"
                   class="button button-primary btn btn-primary">{{ button_retry }}</a>
            </div>
        </div>
    {% else %}
        <div class="container-fluid">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_step2_list_title }}</h3>
                </div>
                <div class="panel-body">
                    <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-email-list"
                          class="form-horizontal">
                        <div class="alert alert-info"><i class="fa fa-info-circle"></i> {{ text_step2_list_select_finalize }}
                            <button type="button" class="close" data-dismiss="alert">&times;</button>
                        </div>
                        <input type="hidden" name="user_id" value="{{ user_id }}"/>
                        <input type="hidden" name="api_key" value="{{ api_key }}"/>
                        <div class="form-group">
                            <label class="col-sm-2 control-label" for="email-list">{{ entry_list_id }}</label>
                            <div class="col-sm-10">
                                <select name="list_id" id="email-list" class="form-control">
                                    <option value="">{{ text_please_select_list }}</option>
                                    {% for email_list in email_lists %}
                                        <option {% if email_lists_length == 1 %}selected{% endif %} value="{{ email_list.id }}">{{ email_list.name }}</option>
                                    {% endfor %}
                                </select>
                                <span id="email-list-error" style="display: none; color: #ff0000;"><br />{{ text_step2_list_select_proceed }}</span>
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="col-sm-2"></div>
                            <div class="col-sm-10">
                                <button type="button" class="btn btn-primary" id="save_action">{{ button_save }}</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <script type="text/javascript">
            (function($) {
                var formEmailList = $('#form-email-list');

                $(document).on('click', '#save_action', function(e) {
                    e.preventDefault();
                    e.stopPropagation();

                    if ($('#email-list').val() == '') {
                        $('#email-list-error').show();
                    } else {
                        $('#email-list-error').hide();
                        $(formEmailList).submit();
                    }
                });
            })(jQuery);
        </script>
    {% endif %}
</div>
{{ footer }}
